type Address = struct {
  h160,
};

constructor {
  Create : (token_id: Address);
};

service Vault {
  AddMarket : (program_id: Address) -> null;
  /// Debug/testing helper to mint balance without requiring market/admin routing.
  /// Only available when compiled with the `debug` feature.
  DebugDeposit : (_user: Address, _amount: u128) -> null;
  SetQuarantinePeriod : (period: u64) -> null;
  TransferToMarket : (market_id: Address, amount: u128) -> null;
  UpdateFeeRate : (new_rate: u128) -> null;
  VaultDeposit : (user: Address, amount: u128) -> null;
  VaultForceExit : (user: Address, amount: u128) -> null;
  VaultWithdraw : (user: Address, amount: u128) -> null;
  query Admin : () -> Address;
  query GetBalance : (user: Address) -> u128;
  query IsAuthorized : (program_id: Address) -> bool;

  events {
    Deposit: struct {
      user: Address,
      token: Address,
      amount: u128,
      balance_after: u128,
    };
    Withdrawal: struct {
      user: Address,
      token: Address,
      amount: u128,
      status: str,
    };
    FeesClaimed: struct {
      token: Address,
      amount: u128,
    };
    QuarantineReleased: struct {
      user: Address,
      token: Address,
      amount: u128,
      balance_after: u128,
    };
  }
};

